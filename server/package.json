{
  "name": "autos-server",
  "version": "1.0.0",
  "description": "API REST - Anuncios de Automóviles (MVP Grupal #05)",
  "main": "index.js",
  "scripts": {
    "start": "node index.js",
    "dev": "nodemon index.js",
    "db:migrate": "npx sequelize-cli db:migrate",
